{
  "name": "create-js-stack",
  "version": "0.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@erquhart/convex-oss-stats": "^0.8.2",
      "@types/fs-extra": "^11.0.4",
      "@types/node": "^25.6.0",
      "better-result": "^2.8.2",
      "convex": "^1.35.1",
      "convex-helpers": "^0.1.115",
      "handlebars": "^4.7.9",
      "oxfmt": "^0.46.0",
      "ts-morph": "^28.0.0",
      "tsdown": "^0.21.9",
      "typescript": "^6.0.3",
      "yaml": "^2.8.3",
      "zod": "^4.3.6"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:cli": "turbo run dev --filter=create-js-stack",
    "cli": "cd apps/cli && node dist/cli.js",
    "smoke:publish": "bun run scripts/publish-smoke.ts",
    "dev:web": "turbo run dev --filter=web",
    "build:web": "turbo run build --filter=web",
    "build:cli": "turbo run build --filter=create-js-stack",
    "lint": "turbo run lint",
    "check": "oxfmt . && oxlint .",
    "prepare": "lefthook install",
    "release": "bun run scripts/release.ts",
    "bump": "bun run scripts/bump-version.ts",
    "canary": "bun run scripts/canary-release.ts",
    "cleanup-previews": "bun run scripts/cleanup-previews.ts",
    "deploy:convex": "turbo run --filter=@create-js-stack/backend deploy",
    "deploy:web": "turbo run deploy --filter=web",
    "generate": "turbo run generate-schema --filter=web",
    "deploy": "turbo run deploy --filter=web"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "changelogithub": "^14.0.0",
    "lefthook": "^2.1.6",
    "lint-staged": "^16.4.0",
    "oxfmt": "catalog:",
    "oxlint": "^1.61.0",
    "turbo": "^2.9.6",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json,jsonc,md,yml,yaml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{ts,tsx,js,jsx,mjs,cjs,mts,cts}": [
      "oxlint"
    ]
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "bun@1.3.13"
}
