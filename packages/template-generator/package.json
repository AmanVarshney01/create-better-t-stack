{
  "name": "@create-js-stack/template-generator",
  "version": "1.2.6",
  "description": "Virtual file system generator for Create-JS-Stack templates - works in browsers and Node.js",
  "keywords": [
    "cli",
    "create-js-stack",
    "template-generator",
    "typescript",
    "virtual-fs"
  ],
  "homepage": "https://create-js-stack.dev/",
  "license": "MIT",
  "author": "Aman Varshney",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riteshintro/create-js-stack.git",
    "directory": "packages/template-generator"
  },
  "files": [
    "dist",
    "templates-binary"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./fs-writer": {
      "types": "./dist/fs-writer.d.mts",
      "default": "./dist/fs-writer.mjs"
    },
    "./template-reader": {
      "types": "./dist/template-reader.d.mts",
      "default": "./dist/template-reader.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate-templates": "bun scripts/generate-templates.ts",
    "prebuild": "bun run generate-templates",
    "build": "tsdown",
    "prepublishOnly": "bun run build",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@create-js-stack/types": "workspace:*",
    "better-result": "^2.8.2",
    "handlebars": "^4.7.9",
    "memfs": "^4.57.2",
    "pathe": "^2.0.3",
    "ts-morph": "^28.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "fs-extra": "^11.3.4",
    "is-binary-path": "^3.0.0",
    "tinyglobby": "^0.2.15",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3"
  }
}
