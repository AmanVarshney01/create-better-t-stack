import { createFileRoute } from "@tanstack/react-router";
import { handler } from "@/lib/auth-server";

export const Route = createFileRoute("/api/auth/$")({
  server: {
      POST: ({ request }) => handler(request),
    },
  
    handlers: {
      GET: ({ request }) => handler(request),},
});
