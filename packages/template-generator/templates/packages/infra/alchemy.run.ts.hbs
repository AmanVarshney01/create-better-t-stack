export default Alchemy.Stack(
  "{{projectName}}",
  {
    providers: Cloudflare.providers(),
    state: Cloudflare.state(),
  },
  Effect.gen(function* () {
    {{#if (eq serverDeploy "cloudflare")}}
    const serverWorker = yield* server;
    {{/if}}
    {{#if (and (eq webDeploy "cloudflare") (eq backend "self"))}}
    const webWorker = yield* web;
    {{else if (eq webDeploy "cloudflare")}}
    {{#if (includes frontend "next")}}
    const webWorker = yield* Cloudflare.Website.StaticSite(
      "web",
      Effect.gen(function* () {
        return {
          cwd: "../../apps/web",
          command: "{{packageManager}} run build:cloudflare",
          outdir: ".open-next/assets",
          main: "../../apps/web/.open-next/worker.js",
          bundle: false,
          compatibility: {
            flags: ["nodejs_compat"],
          },
          env: {
            {{#if (eq backend "convex")}}
            NEXT_PUBLIC_CONVEX_URL: yield* Config.string("NEXT_PUBLIC_CONVEX_URL"),
            {{#if (eq auth "better-auth")}}
            NEXT_PUBLIC_CONVEX_SITE_URL: yield* Config.string("NEXT_PUBLIC_CONVEX_SITE_URL"),
            {{/if}}
            {{else}}
            {{#if (eq serverDeploy "cloudflare")}}
            NEXT_PUBLIC_SERVER_URL: serverWorker.url.as<string>(),
            {{else}}
            NEXT_PUBLIC_SERVER_URL: yield* Config.string("NEXT_PUBLIC_SERVER_URL"),
            {{/if}}
            {{/if}}
            {{#if (eq auth "clerk")}}
            CLERK_SECRET_KEY: yield* Config.redacted("CLERK_SECRET_KEY"),
            NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY: yield* Config.string("NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY"),
            {{/if}}
          },
          dev: {
            command: "{{packageManager}} run dev:bare",
            url: "http://localhost:3001",
          },
        };
      }).pipe(Effect.orDie),
    );
    {{else if (includes frontend "nuxt")}}
    const webWorker = yield* Cloudflare.Website.StaticSite(
      "web",
      Effect.gen(function* () {
        return {
          cwd: "../../apps/web",
          command: "{{packageManager}} run build",
          outdir: ".output/public",
          main: "../../apps/web/.output/server/index.mjs",
          bundle: false,
          compatibility: {
            flags: ["nodejs_compat"],
          },
          env: {
            {{#if (eq backend "convex")}}
            NUXT_PUBLIC_CONVEX_URL: yield* Config.string("NUXT_PUBLIC_CONVEX_URL"),
            {{#if (eq auth "better-auth")}}
            NUXT_PUBLIC_CONVEX_SITE_URL: yield* Config.string("NUXT_PUBLIC_CONVEX_SITE_URL"),
            {{/if}}
            {{else}}
            {{#if (eq serverDeploy "cloudflare")}}
            NUXT_PUBLIC_SERVER_URL: serverWorker.url.as<string>(),
            {{else}}
            NUXT_PUBLIC_SERVER_URL: yield* Config.string("NUXT_PUBLIC_SERVER_URL"),
            {{/if}}
            {{/if}}
          },
          dev: {
            command: "{{packageManager}} run dev:bare",
            url: "http://localhost:3001",
          },
        };
      }).pipe(Effect.orDie),
    );
    {{else if (includes frontend "svelte")}}
    const webWorker = yield* Cloudflare.Website.StaticSite(
      "web",
      // _worker.js is a shim importing outside its directory, so it must be bundled
      Effect.gen(function* () {
        return {
          cwd: "../../apps/web",
          command: "{{packageManager}} run build",
          outdir: ".svelte-kit/cloudflare",
          main: "../../apps/web/.svelte-kit/cloudflare/_worker.js",
          compatibility: {
            flags: ["nodejs_compat"],
          },
          env: {
            {{#if (eq backend "convex")}}
            PUBLIC_CONVEX_URL: yield* Config.string("PUBLIC_CONVEX_URL"),
            {{#if (eq auth "better-auth")}}
            PUBLIC_CONVEX_SITE_URL: yield* Config.string("PUBLIC_CONVEX_SITE_URL"),
            {{/if}}
            {{else}}
            {{#if (eq serverDeploy "cloudflare")}}
            PUBLIC_SERVER_URL: serverWorker.url.as<string>(),
            {{else}}
            PUBLIC_SERVER_URL: yield* Config.string("PUBLIC_SERVER_URL"),
            {{/if}}
            {{/if}}
          },
          dev: {
            command: "{{packageManager}} run dev:bare",
            url: "http://localhost:5173",
          },
        };
      }).pipe(Effect.orDie),
    );
    {{else if (includes frontend "astro")}}
    const webWorker = yield* Cloudflare.Website.StaticSite(
      "web",
      Effect.gen(function* () {
        return {
          cwd: "../../apps/web",
          command: "{{packageManager}} run build",
          outdir: "dist/client",
          main: "../../apps/web/dist/server/entry.mjs",
          bundle: false,
          compatibility: {
            flags: ["nodejs_compat"],
          },
          env: {
            // the astro cloudflare adapter expects a SESSION KV binding
            SESSION: Cloudflare.KV.Namespace("session"),
            {{#if (eq serverDeploy "cloudflare")}}
            PUBLIC_SERVER_URL: serverWorker.url.as<string>(),
            {{else}}
            PUBLIC_SERVER_URL: yield* Config.string("PUBLIC_SERVER_URL"),
            {{/if}}
          },
          dev: {
            command: "{{packageManager}} run dev:bare",
            url: "http://localhost:4321",
          },
        };
      }).pipe(Effect.orDie),
    );
    {{else if (includes frontend "tanstack-start")}}
    const webWorker = yield* Cloudflare.Website.Vite("web", {
      rootDir: "../../apps/web",
      compatibility: {
        flags: ["nodejs_compat"],
      },
      env: {
        {{#if (eq backend "convex")}}
        VITE_CONVEX_URL: Config.string("VITE_CONVEX_URL"),
        {{#if (eq auth "better-auth")}}
        VITE_CONVEX_SITE_URL: Config.string("VITE_CONVEX_SITE_URL"),
        {{/if}}
        {{else}}
        {{#if (eq serverDeploy "cloudflare")}}
        VITE_SERVER_URL: serverWorker.url.as<string>(),
        {{else}}
        VITE_SERVER_URL: Config.string("VITE_SERVER_URL"),
        {{/if}}
        {{/if}}
        {{#if (eq auth "clerk")}}
        CLERK_SECRET_KEY: Config.redacted("CLERK_SECRET_KEY"),
        VITE_CLERK_PUBLISHABLE_KEY: Config.string("VITE_CLERK_PUBLISHABLE_KEY"),
        {{/if}}
      },
    });
    {{else if (includes frontend "react-router")}}
    const webWorker = yield* Cloudflare.Website.Vite("web", {
      rootDir: "../../apps/web",
      compatibility: {
        flags: ["nodejs_compat"],
      },
      env: {
        {{#if (eq backend "convex")}}
        VITE_CONVEX_URL: Config.string("VITE_CONVEX_URL"),
        {{#if (eq auth "better-auth")}}
        VITE_CONVEX_SITE_URL: Config.string("VITE_CONVEX_SITE_URL"),
        {{/if}}
        {{else}}
        {{#if (eq serverDeploy "cloudflare")}}
        VITE_SERVER_URL: serverWorker.url.as<string>(),
        {{else}}
        VITE_SERVER_URL: Config.string("VITE_SERVER_URL"),
        {{/if}}
        {{/if}}
      },
    });
    {{else if (or (includes frontend "tanstack-router") (includes frontend "solid"))}}
    const webWorker = yield* Cloudflare.Website.StaticSite(
      "web",
      // Website.Vite skips pure-client builds on this alchemy beta; build directly
      Effect.gen(function* () {
        return {
          cwd: "../../apps/web",
          command: "{{packageManager}} run build",
          outdir: "dist",
          assets: {
            htmlHandling: "auto-trailing-slash" as const,
            notFoundHandling: "single-page-application" as const,
          },
          env: {
            {{#if (eq backend "convex")}}
            VITE_CONVEX_URL: yield* Config.string("VITE_CONVEX_URL"),
            {{#if (eq auth "better-auth")}}
            VITE_CONVEX_SITE_URL: yield* Config.string("VITE_CONVEX_SITE_URL"),
            {{/if}}
            {{else}}
            {{#if (eq serverDeploy "cloudflare")}}
            VITE_SERVER_URL: serverWorker.url.as<string>(),
            {{else}}
            VITE_SERVER_URL: yield* Config.string("VITE_SERVER_URL"),
            {{/if}}
            {{/if}}
          },
          dev: {
            command: "{{packageManager}} run dev:bare",
            url: "http://localhost:3001",
          },
        };
      }).pipe(Effect.orDie),
    );
    {{/if}}
    {{/if}}

    return {
      {{#if (eq webDeploy "cloudflare")}}
      web: webWorker.url,
      {{/if}}
      {{#if (eq serverDeploy "cloudflare")}}
      server: serverWorker.url,
      {{/if}}
    };
  }),
);
