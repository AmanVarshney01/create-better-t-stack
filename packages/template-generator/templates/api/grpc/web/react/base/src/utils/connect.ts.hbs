{{#if (includes frontend 'next')}}
import { createConnectTransport } from "@connectrpc/connect-web";
import { createClient } from "@connectrpc/connect";
import { HealthService, ExampleService } from "@{{projectName}}/api/generated/service_connect";
import { env } from "@{{projectName}}/env/web";

{{> getServerUrl}}

const transport = createConnectTransport({
  baseUrl: {{#if (eq backend "self")}}typeof window !== "undefined" ? `${window.location.origin}/api/connect` : "/api/connect"{{else}}`${getServerUrl(env.NEXT_PUBLIC_SERVER_URL)}`{{/if}},
  fetch,
{{#if (eq auth "better-auth")}}
  credentials: "include",
{{/if}}
});

export const healthClient = createClient(HealthService, transport);
export const exampleClient = createClient(ExampleService, transport);

{{else}}
import { createConnectTransport } from "@connectrpc/connect-web";
import { createClient } from "@connectrpc/connect";
import { HealthService, ExampleService } from "@{{projectName}}/api/generated/service_connect";
import { env } from "@{{projectName}}/env/web";

{{> getServerUrl}}

const transport = createConnectTransport({
  baseUrl: {{#if (eq backend "self")}}""{{else}}`${getServerUrl(env.VITE_SERVER_URL)}`{{/if}},
  fetch,
{{#if (eq auth "better-auth")}}
  credentials: "include",
{{/if}}
});

export const healthClient = createClient(HealthService, transport);
export const exampleClient = createClient(ExampleService, transport);
{{/if}}
