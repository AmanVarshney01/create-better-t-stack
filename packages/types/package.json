{
  "name": "@create-js-stack/types",
  "version": "1.2.6",
  "description": "TypeScript types and schemas for create-js-stack CLI",
  "keywords": [
    "cli",
    "create-js-stack",
    "schemas",
    "types",
    "typescript"
  ],
  "homepage": "https://create-js-stack.dev/",
  "license": "MIT",
  "author": "Aman Varshney",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riteshintro/create-js-stack.git",
    "directory": "packages/types"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./schemas": {
      "types": "./dist/schemas.d.mts",
      "default": "./dist/schemas.mjs"
    },
    "./json-schema": {
      "types": "./dist/json-schema.d.mts",
      "default": "./dist/json-schema.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3"
  }
}
